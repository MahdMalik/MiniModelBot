      "source": [
        "import tensorflow as tf\n",
        "from datasets import load_dataset\n",
        "\n",
        "dataset = load_dataset(\"nickmuchi/rugd-dataset-all\")\n",
        "tf_dataset = dataset.with_format(\"tensorflow\")\n",
        "train_tf = tf_dataset[\"train\"]\n",
        "\n",
        "sample = train_tf[0]\n",
        "print(type(sample[\"image\"]))"
      ]
